{
  "name": "globalise-design-system",
  "private": true,
  "description": "Globalise design system monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/globalise-huygens/globalise-design-system.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @globalise/design-system build",
    "build:docs": "pnpm --filter @globalise/design-system build && pnpm --filter docs build",
    "dev": "pnpm --filter @globalise/design-system dev",
    "dev:docs": "pnpm --filter @globalise/design-system build && pnpm --filter docs dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md,mdx}\""
  },
  "devDependencies": {
    "@upleveled/eslint-config-upleveled": "^4.0.10",
    "prettier": "^3.8.1"
  }
}
