{
  "name": "globalise-design-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Globalise design system React showcase",
  "repository": {
    "type": "git",
    "url": "https://github.com/globalise-huygens/globalise-design-system.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "typecheck": "tsc -b",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md,mdx}\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
